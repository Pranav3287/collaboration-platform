{
  "name": "collaboration-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Collaboration Platform - run backend + frontend with one command",
  "scripts": {
    "prestart": "npx kill-port 8080 3000",
    "start": "concurrently -k -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run server\" \"npm run client:wait\"",
    "server": "mvnw.cmd spring-boot:run",
    "client": "npm start --prefix client",
    "client:wait": "wait-on tcp:localhost:8080 -t 180000 && npm start --prefix client",
    "install-all": "npm install && npm install --prefix client",
    "postinstall": "npm install --prefix client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "kill-port": "^2.0.1",
    "wait-on": "^8.0.1"
  }
}
